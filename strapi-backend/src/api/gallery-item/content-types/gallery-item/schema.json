{
  "kind": "collectionType",
  "collectionName": "gallery_items",
  "info": {
    "singularName": "gallery-item",
    "pluralName": "gallery-items",
    "displayName": "gallery-item"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "image": {
      "type": "media",
      "multiple": false,
      "required": true,
      "allowedTypes": [
        "images",
        "files"
      ]
    },
    "gallery_tag": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::gallery-tag.gallery-tag",
      "inversedBy": "gallery_items"
    },
    "order": {
      "type": "integer"
    },
    "featured": {
      "type": "boolean"
    },
    "slug": {
      "type": "uid",
      "targetField": "title"
    }
  }
}
